# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
/.env
/.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/extras/
/lib/generated/prisma

/scripts

/.vscode/
/.vscode/*

/queue
/queue/*

/.agents
/.agents/*

/stitch.json
/skills-lock.json

/.gemini
/.gemini/*

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Local Playwright init scaffolding (do not commit)
/new-project/
/tests/
/e2e/
/playwright.config.ts
/.github/workflows/playwright.yml
